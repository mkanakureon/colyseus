{
  "extends": "../tsconfig/tsconfig.all.json",
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ESNext",
    "customConditions": ["@source"],
    "outDir": "build",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "server.ts", "client-cli.ts"]
}
